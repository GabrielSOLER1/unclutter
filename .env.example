# Clé API Gemini — obtenir gratuitement sur https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Port d'écoute du serveur (optionnel, 3000 par défaut)
PORT=3000

# Webhook (Slack ou Discord) notifié automatiquement quand un ticket est
# qualifié à risque. Optionnel : laisser vide désactive l'alerte.
ALERT_WEBHOOK_URL=
